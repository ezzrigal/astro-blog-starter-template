				whatsappBtn.addEventListener('click', () => {
					const display = document.getElementById('calcPriceDisplay');
					const priceText = display ? display.textContent : '600 - 750 ريال';
					
					const text = `السلام عليكم ورحمة الله وبركاته، أود حجز موعد نقل أثاث بالرياض.
تفاصيل الطلب التقديرية:
- نوع المسكن: ${homeTypeText}
- حجم الأثاث: ${roomText}
- التغليف المطلوب: ${packingText}
- الطابق والصعوبة: ${floorText}
- السعر التقديري للموقع: ${priceText}

أرجو التواصل لتأكيد الموعد والمعاينة المجانية.`;
					
					const encoded = encodeURIComponent(text);
					window.open(`https://wa.me/966500000000?text=${encoded}`, '_blank');
				});
			}

			// Accordion logic
			const faqTriggers = document.querySelectorAll('.faq-trigger');
			faqTriggers.forEach(trigger => {
				trigger.addEventListener('click', () => {
					const parent = trigger.parentElement;
					if (!parent) return;
					
					const content = parent.querySelector('.faq-content') as HTMLElement;
					if (!content) return;

					const isActive = parent.classList.contains('active');

					// Close other active FAQ items
					document.querySelectorAll('.faq-item').forEach(item => {
						item.classList.remove('active');
						const itemContent = item.querySelector('.faq-content') as HTMLElement;
						if (itemContent) itemContent.style.maxHeight = '0';
					});

					if (!isActive) {
						parent.classList.add('active');
						content.style.maxHeight = content.scrollHeight + 'px';
					} else {
						parent.classList.remove('active');
						content.style.maxHeight = '0';
					}
				});
			});
		</script>
	</body>
</html>
