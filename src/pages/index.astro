---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="ar" dir="rtl">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			/* Page Specific Styles (Scoped) */
			
			/* Hero Section */
			.hero {
				padding: 9rem 0 6rem 0;
				background: linear-gradient(135deg, rgba(15, 118, 110, 0.95) 0%, rgba(15, 23, 42, 0.98) 100%), 
							url('/blog-placeholder-about.jpg') no-repeat center center / cover;
				color: var(--white);
				position: relative;
				overflow: hidden;
			}

			.hero::before {
				content: '';
				position: absolute;
				top: 0;
				left: 0;
				right: 0;
				bottom: 0;
				background: radial-gradient(circle at 15% 50%, rgba(217, 119, 6, 0.15), transparent 40%);
				pointer-events: none;
			}

			.hero-grid {
				display: grid;
				grid-template-columns: 1.2fr 1fr;
				gap: 3rem;
				align-items: center;
			}

			@media (max-width: 992px) {
				.hero {
					padding: 7rem 0 4rem 0;
				}
				.hero-grid {
					grid-template-columns: 1fr;
					text-align: center;
				}
			}

			.hero-content h1 {
				color: var(--white);
				font-size: 3.25rem;
				font-weight: 800;
				margin-bottom: 1.5rem;
				line-height: 1.25;
			}

			.hero-content h1 span {
				background: linear-gradient(90deg, #fbbf24, #f59e0b);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
			}

			.hero-content p {
				color: #cbd5e1; /* Slate 300 */
				font-size: 1.15rem;
				margin-bottom: 2.5rem;
				max-width: 650px;
			}

			@media (max-width: 992px) {
				.hero-content p {
					margin-left: auto;
					margin-right: auto;
				}
			}

			.hero-badge {
				display: inline-flex;
				align-items: center;
				gap: 0.5rem;
				background-color: rgba(217, 119, 6, 0.2);
				border: 1px solid rgba(217, 119, 6, 0.4);
				color: #fef3c7; /* Amber 100 */
				padding: 0.4rem 1rem;
				border-radius: 50px;
				font-size: 0.9rem;
				font-weight: 700;
				margin-bottom: 1.5rem;
			}

			.hero-actions {
				display: flex;
				gap: 1rem;
				flex-wrap: wrap;
			}

			@media (max-width: 992px) {
				.hero-actions {
					justify-content: center;
				}
			}

			.hero-card {
				background: rgba(255, 255, 255, 0.08);
				backdrop-filter: blur(16px);
				-webkit-backdrop-filter: blur(16px);
				border: 1px solid rgba(255, 255, 255, 0.15);
				border-radius: 24px;
				padding: 2.5rem;
				box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
			}

			.hero-card h3 {
				color: var(--white);
				margin-bottom: 1.5rem;
				font-size: 1.4rem;
				border-bottom: 1px solid rgba(255, 255, 255, 0.1);
				padding-bottom: 0.75rem;
			}

			.feature-bullet {
				display: flex;
				align-items: center;
				gap: 1rem;
				margin-bottom: 1.25rem;
			}

			.feature-bullet:last-child {
				margin-bottom: 0;
			}

			.bullet-icon {
				width: 36px;
				height: 36px;
				border-radius: 50%;
				background-color: var(--accent);
				display: flex;
				align-items: center;
				justify-content: center;
				flex-shrink: 0;
				color: var(--white);
			}

			.bullet-text h4 {
				color: var(--white);
				font-size: 1rem;
				margin: 0;
			}

			.bullet-text p {
				color: #94a3b8;
				font-size: 0.85rem;
				margin: 0;
			}

			/* Stats Section */
			.stats-bar {
				background-color: var(--white);
				padding: 2.5rem 0;
				margin-top: -3rem;
				position: relative;
				z-index: 10;
				border-radius: 16px;
				box-shadow: var(--shadow-lg);
				border: 1px solid var(--border-color);
			}

			.stats-grid {
				display: grid;
				grid-template-columns: repeat(4, 1fr);
				gap: 2rem;
				text-align: center;
			}

			@media (max-width: 992px) {
				.stats-grid {
					grid-template-columns: repeat(2, 1fr);
					gap: 2rem;
				}
			}

			@media (max-width: 576px) {
				.stats-grid {
					grid-template-columns: 1fr;
					gap: 1.5rem;
				}
			}

			.stat-item {
				display: flex;
				flex-direction: column;
				align-items: center;
			}

			.stat-num {
				font-size: 2.5rem;
				font-weight: 800;
				color: var(--primary);
				line-height: 1.1;
			}

			.stat-label {
				font-size: 0.95rem;
				color: var(--text-muted);
				font-weight: 600;
				margin-top: 0.5rem;
			}

			/* Services Section */
			.services-grid {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 2rem;
				margin-top: 1.5rem;
			}

			@media (max-width: 992px) {
				.services-grid {
					grid-template-columns: repeat(2, 1fr);
				}
			}

			@media (max-width: 768px) {
				.services-grid {
					grid-template-columns: 1fr;
				}
			}

			.service-card {
				position: relative;
				overflow: hidden;
			}

			.service-icon {
				width: 60px;
				height: 60px;
				border-radius: 12px;
				background-color: var(--primary-light);
				color: var(--primary);
				display: flex;
				align-items: center;
				justify-content: center;
				margin-bottom: 1.5rem;
				transition: var(--transition-smooth);
			}

			.service-card:hover .service-icon {
				background-color: var(--primary);
				color: var(--white);
				transform: rotate(5deg) scale(1.05);
			}

			.service-card h3 {
				margin-bottom: 0.75rem;
				font-size: 1.3rem;
			}

			.service-card p {
				font-size: 0.95rem;
				line-height: 1.6;
			}

			/* Calculator Section */
			.calculator-section {
				background-color: #f1f5f9;
				border-top: 1px solid var(--border-color);
				border-bottom: 1px solid var(--border-color);
			}

			.calc-container {
				max-width: 800px;
				margin: 0 auto;
			}

			.calc-card {
				background-color: var(--white);
				border-radius: 24px;
				padding: 3rem;
				box-shadow: var(--shadow-lg);
				border: 1px solid var(--border-color);
			}

			@media (max-width: 576px) {
				.calc-card {
					padding: 1.5rem;
				}
			}

			.calc-group {
				margin-bottom: 2rem;
			}

			.calc-label {
				display: block;
				font-weight: 700;
				margin-bottom: 0.75rem;
				color: var(--text-dark);
				font-size: 1.05rem;
			}

			.calc-options {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 1rem;
			}

			@media (max-width: 576px) {
				.calc-options {
					grid-template-columns: 1fr;
					gap: 0.5rem;
				}
			}

			.calc-btn-option {
				background-color: var(--bg-light);
				border: 2px solid var(--border-color);
				border-radius: 12px;
				padding: 1rem;
				text-align: center;
				cursor: pointer;
				font-weight: 600;
				transition: var(--transition-smooth);
				display: flex;
				flex-direction: column;
				align-items: center;
				gap: 0.25rem;
			}

			.calc-btn-option:hover {
				border-color: var(--primary-hover);
				background-color: var(--primary-light);
			}

			.calc-btn-option.selected {
				border-color: var(--primary);
				background-color: var(--primary-light);
				color: var(--primary);
			}

			.calc-btn-option span.sub-text {
				font-size: 0.8rem;
				color: var(--text-muted);
				font-weight: normal;
			}

			.calc-btn-option.selected span.sub-text {
				color: var(--primary);
			}

			.calc-result-box {
				background: linear-gradient(135deg, var(--primary) 0%, #0d9488 100%);
				color: var(--white);
				padding: 2rem;
				border-radius: 16px;
				text-align: center;
				margin-top: 2.5rem;
				box-shadow: var(--shadow-md);
			}

			.calc-price {
				font-size: 2.5rem;
				font-weight: 800;
				color: #fef08a; /* Yellow 200 */
				margin: 0.5rem 0;
			}

			.calc-disclaimer {
				font-size: 0.8rem;
				color: #ccfbf1; /* Teal 100 */
				margin-top: 0.5rem;
			}

			.calc-whatsapp-btn {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				gap: 0.75rem;
				background-color: #25D366;
				color: var(--white);
				font-weight: 700;
				width: 100%;
				padding: 1rem;
				border-radius: 12px;
				margin-top: 1.5rem;
				border: none;
				cursor: pointer;
				font-size: 1.1rem;
				box-shadow: 0 4px 15px rgba(37, 211, 102, 0.3);
				transition: var(--transition-smooth);
			}

			.calc-whatsapp-btn:hover {
				transform: translateY(-2px);
				box-shadow: 0 6px 20px rgba(37, 211, 102, 0.4);
				background-color: #20ba59;
			}

			/* How It Works */
			.steps-grid {
				display: grid;
				grid-template-columns: repeat(4, 1fr);
				gap: 2rem;
				margin-top: 2rem;
				position: relative;
			}

			@media (max-width: 992px) {
				.steps-grid {
					grid-template-columns: repeat(2, 1fr);
				}
			}

			@media (max-width: 576px) {
				.steps-grid {
					grid-template-columns: 1fr;
				}
			}

			.step-card {
				text-align: center;
				position: relative;
			}

			.step-num {
				width: 50px;
				height: 50px;
				border-radius: 50%;
				background-color: var(--accent);
				color: var(--white);
				display: flex;
				align-items: center;
				justify-content: center;
				font-size: 1.25rem;
				font-weight: 800;
				margin: 0 auto 1.5rem auto;
				border: 4px solid var(--accent-light);
				box-shadow: var(--shadow-sm);
			}

			.step-card h3 {
				font-size: 1.2rem;
				margin-bottom: 0.5rem;
			}

			.step-card p {
				font-size: 0.9rem;
				line-height: 1.6;
			}

			/* FAQ Section */
			.faq-container {
				max-width: 800px;
				margin: 0 auto;
				display: flex;
				flex-direction: column;
				gap: 1rem;
			}

			.faq-item {
				background-color: var(--white);
				border: 1px solid var(--border-color);
				border-radius: 12px;
				overflow: hidden;
				transition: var(--transition-smooth);
			}

			.faq-trigger {
				width: 100%;
				background: none;
				border: none;
				padding: 1.25rem 1.5rem;
				text-align: right;
				font-size: 1.1rem;
				font-weight: 700;
				color: var(--text-dark);
				cursor: pointer;
				display: flex;
				justify-content: space-between;
				align-items: center;
				gap: 1rem;
				transition: var(--transition-smooth);
			}

			.faq-trigger:hover {
				background-color: var(--bg-light);
				color: var(--primary);
			}

			.faq-icon {
				transition: transform 0.3s ease;
				color: var(--primary);
			}

			.faq-item.active .faq-icon {
				transform: rotate(180deg);
			}

			.faq-content {
				max-height: 0;
				overflow: hidden;
				transition: max-height 0.3s ease-out, padding 0.3s ease;
				padding: 0 1.5rem;
				background-color: var(--white);
				border-top: 0px solid var(--border-color);
			}

			.faq-item.active .faq-content {
				padding: 1rem 1.5rem 1.5rem 1.5rem;
				border-top-width: 1px;
			}

			.faq-content p {
				font-size: 0.95rem;
				margin: 0;
				line-height: 1.7;
			}

			/* CTA Banner */
			.cta-banner {
				background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
				color: var(--white);
				border-radius: 24px;
				padding: 4rem 2rem;
				text-align: center;
				position: relative;
				overflow: hidden;
				box-shadow: var(--shadow-xl);
			}

			.cta-banner::before {
				content: '';
				position: absolute;
				top: -50%;
				left: -50%;
				width: 200%;
				height: 200%;
				background: radial-gradient(circle, rgba(217, 119, 6, 0.1) 0%, transparent 50%);
				pointer-events: none;
			}

			.cta-banner h2 {
				color: var(--white);
				font-size: 2.25rem;
				margin-bottom: 1rem;
			}

			.cta-banner h2::after {
				display: none;
			}

			.cta-banner p {
				color: #ccfbf1;
				font-size: 1.1rem;
				max-width: 600px;
				margin: 0 auto 2.5rem auto;
			}

			.cta-banner-buttons {
				display: flex;
				justify-content: center;
				gap: 1.5rem;
				flex-wrap: wrap;
			}
		</style>
	</head>
	<body>
		<Header />
		
		<!-- Hero Section -->
		<section id="hero" class="hero">
			<div class="container hero-grid">
				<!-- Hero Text Content -->
				<div class="hero-content">
					<div class="hero-badge">
						<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="6 2 18 2 18 6 6 6 6 2"/><rect x="3" y="6" width="18" height="16" rx="2"/><line x1="10" y1="12" x2="14" y2="12"/></svg>
						<span>خصم 20% لفترة محدودة على جميع خدمات النقل بالرياض</span>
					</div>
					<h1>شركة نقل عفش بالرياض <br><span>أمان، سرعة، واحترافية</span></h1>
					<p>
						نوفر لك تجربة نقل أثاث خالية من المتاعب بفضل خدمات الفك والتركيب والتغليف المتكاملة. نلتزم بأعلى معايير السلامة والاحترافية لحماية ممتلكاتك وبأسعار تناسب الجميع.
					</p>
					<div class="hero-actions">
						<a href="tel:+966500000000" class="btn btn-accent">
							<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
							<span>اتصل بنا الآن</span>
						</a>
						<a href="#calculator" class="btn btn-outline" style="border-color: var(--white); color: var(--white);">
							<span>احسب تكلفة النقل</span>
						</a>
					</div>
				</div>

				<!-- Floating Hero Card -->
				<div class="hero-card animate-float">
					<h3>لماذا يثق بنا العملاء؟</h3>
					
					<div class="feature-bullet">
						<div class="bullet-icon">
							<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
						</div>
						<div class="bullet-text">
							<h4>ضمان حقيقي وشامل</h4>
							<p>نضمن سلامة جميع قطع الأثاث ونتحمل المسؤولية كاملة.</p>
						</div>
					</div>

					<div class="feature-bullet">
						<div class="bullet-icon">
							<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
						</div>
						<div class="bullet-text">
							<h4>نجارين وفنيين متخصصين</h4>
							<p>فك وتركيب غرف النوم والمطابخ والمكيفات بأقصى دقة.</p>
						</div>
					</div>

					<div class="feature-bullet">
						<div class="bullet-icon">
							<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
						</div>
						<div class="bullet-text">
							<h4>سيارات دينا مغلقة مخصصة</h4>
							<p>لحماية الأثاث من الغبار، الحرارة والأمطار أثناء التنقل.</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Statistics Section -->
		<div class="container">
			<div class="stats-bar">
				<div class="stats-grid">
					<div class="stat-item">
						<span class="stat-num">+10</span>
						<span class="stat-label">سنوات من الخبرة</span>
					</div>
					<div class="stat-item">
						<span class="stat-num">+5,000</span>
						<span class="stat-label">عملية نقل ناجحة</span>
					</div>
					<div class="stat-item">
						<span class="stat-num">100%</span>
						<span class="stat-label">نسبة رضا العملاء</span>
					</div>
					<div class="stat-item">
						<span class="stat-num">24/7</span>
						<span class="stat-label">خدمة عملاء متواصلة</span>
					</div>
				</div>
			</div>
		</div>

		<!-- Services Section -->
		<section id="services">
			<div class="container">
				<h2>خدماتنا المتميزة لنقل العفش</h2>
				<p class="text-center" style="max-width: 600px; margin: -1.5rem auto 3rem auto;">
					نقدم باقة متكاملة من خدمات نقل وتجهيز الأثاث في الرياض لتوفير الوقت والجهد على عملائنا الكرام.
				</p>
				
				<div class="services-grid">
					<!-- Service 1 -->
					<div class="card service-card">
						<div class="service-icon">
							<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
						</div>
						<h3>فك وتركيب الأثاث</h3>
						<p>
							نقوم بفك وتركيب جميع أنواع غرف النوم (المحلي والمستورد والمودرن)، المطابخ، الستائر، الشاشات والمكيفات بواسطة نجارين محترفين وفنيين مؤهلين.
						</p>
					</div>

					<!-- Service 2 -->
					<div class="card service-card">
						<div class="service-icon">
							<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
						</div>
						<h3>تغليف الأثاث الاحترافي</h3>
						<p>
							نستخدم أفضل مواد التغليف كالمفرقعات الهوائية (البابلز)، النايلون السميك، الكرتون المقوى ذو الجودة العالية، واللباد، لضمان حماية تامة ضد الخدش والكسر.
						</p>
					</div>

					<!-- Service 3 -->
					<div class="card service-card">
						<div class="service-icon">
							<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
						</div>
						<h3>سيارات نقل حديثة (دينا)</h3>
						<p>
