			let roomText = '1 - 2 غرف';
			let packingText = 'دون تغليف';
			let floorText = 'أرضي / مصعد متوفر';

			function updatePrice() {
				const minPrice = Math.round((basePrice * roomMultiplier) + packingAdd + floorAdd);
				const maxPrice = Math.round(minPrice * 1.25);
				
				const display = document.getElementById('calcPriceDisplay');
				if (display) {
					display.textContent = `${minPrice} - ${maxPrice} ريال سعودي`;
				}
			}

			// Hook up selection elements
			function setupGroup(containerId, callback) {
				const container = document.getElementById(containerId);
				if (!container) return;
				
				const options = container.querySelectorAll('.calc-btn-option');
				options.forEach(opt => {
					opt.addEventListener('click', () => {
						options.forEach(o => o.classList.remove('selected'));
						opt.classList.add('selected');
						callback(opt);
						updatePrice();
					});
				});
			}

			setupGroup('homeTypeOptions', (el) => {
				basePrice = parseFloat(el.getAttribute('data-base') || '600');
				homeTypeText = el.querySelector('span:first-of-type')?.textContent || '';
			});

			setupGroup('roomsOptions', (el) => {
				roomMultiplier = parseFloat(el.getAttribute('data-mult') || '1.0');
				roomText = el.querySelector('span:first-of-type')?.textContent || '';
			});

			setupGroup('packingOptions', (el) => {
				packingAdd = parseFloat(el.getAttribute('data-add') || '0');
				packingText = el.querySelector('span:first-of-type')?.textContent || '';
			});

			setupGroup('floorOptions', (el) => {
				floorAdd = parseFloat(el.getAttribute('data-add') || '0');
				floorText = el.querySelector('span:first-of-type')?.textContent || '';
			});

			// WhatsApp integration button click
			const whatsappBtn = document.getElementById('calcWhatsappBtn');
