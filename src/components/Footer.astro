---
/**
 * src/components/Footer.astro
 * Footer — all contact, address, social links from settings
 */
import {
  COMPANY_NAME_AR, LOGO, PHONE, WHATSAPP_URL,
  EMAIL, ADDRESS, SOCIAL_WHATSAPP, SOCIAL_TWITTER,
  SOCIAL_INSTAGRAM, SOCIAL_SNAPCHAT,
  FOOTER_COPYRIGHT, FOOTER_TAGLINE,
  SERVICE_AREAS, getYearsInBusiness
} from '../lib/settings';

const today = new Date();
const phoneDisplay = PHONE.replace('+966', '0').replace(/(\d{3})(\d{2})(\d{3})(\d{4})/, '$1 $2 $3 $4');
---

<footer class="footer-section">
  <div class="container footer-grid">

    <!-- Column 1: Brand -->
    <div class="footer-col brand-col">
      <img src={LOGO} alt={`${COMPANY_NAME_AR} بالرياض`} class="footer-logo" />
      <p class="brand-desc">
        {COMPANY_NAME_AR} هي خيارك الأول لخدمات نقل الأثاث السكني والتجاري بالرياض.
        نقدم خدمات فك وتغليف وتركيب متكاملة بأيدي فنيين محترفين ومع الضمان.
        خبرة تزيد عن {getYearsInBusiness()} سنوات في خدمة أهالي الرياض.
      </p>
    </div>

    <!-- Column 2: Quick Links -->
    <div class="footer-col">
      <h3 class="col-title">روابط سريعة</h3>
      <ul class="col-links">
        <li><a href="/#hero">الرئيسية</a></li>
        <li><a href="/services">خدماتنا</a></li>
        <li><a href="/#calculator">حاسبة الأسعار</a></li>
        <li><a href="/#why-us">لماذا نحن؟</a></li>
        <li><a href="/#faq">الأسئلة الشائعة</a></li>
        <li><a href="/blog">المدونة</a></li>
      </ul>
    </div>

    <!-- Column 3: Service Areas -->
    <div class="footer-col">
      <h3 class="col-title">مناطق الخدمة</h3>
      <ul class="col-links areas-list">
        {SERVICE_AREAS.slice(0, 8).map((area: string) => (
          <li><span>{area}</span></li>
        ))}
      </ul>
    </div>

    <!-- Column 4: Contact -->
    <div class="footer-col contact-col">
      <h3 class="col-title">معلومات الاتصال</h3>
      <ul class="col-links">
        <li class="contact-item">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          <span>{ADDRESS.district}، {ADDRESS.city}، المملكة العربية السعودية</span>
        </li>
        <li class="contact-item">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          <a href={`tel:${PHONE}`} dir="ltr">{phoneDisplay}</a>
        </li>
        <li class="contact-item">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          <a href={`mailto:${EMAIL}`}>{EMAIL}</a>
        </li>
      </ul>

      <!-- Social Links -->
      <div class="footer-socials">
        {SOCIAL_WHATSAPP && (
          <a href={SOCIAL_WHATSAPP} target="_blank" rel="noopener noreferrer" class="social-icon whatsapp-icon" aria-label="واتساب">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
          </a>
        )}
        {SOCIAL_TWITTER && (
          <a href={SOCIAL_TWITTER} target="_blank" rel="noopener noreferrer" class="social-icon twitter-icon" aria-label="تويتر">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/></svg>
          </a>
        )}
        {SOCIAL_INSTAGRAM && (
          <a href={SOCIAL_INSTAGRAM} target="_blank" rel="noopener noreferrer" class="social-icon instagram-icon" aria-label="انستغرام">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          </a>
        )}
        {SOCIAL_SNAPCHAT && (
          <a href={SOCIAL_SNAPCHAT} target="_blank" rel="noopener noreferrer" class="social-icon snapchat-icon" aria-label="سناب شات">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2z"/></svg>
          </a>
        )}
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container bottom-content">
      <p>&copy; {today.getFullYear()} {FOOTER_COPYRIGHT}</p>
      <p class="developed-by">{FOOTER_TAGLINE}</p>
    </div>
  </div>
</footer>

<style>
  .footer-section { background-color: #0f172a; color: #e2e8f0; padding: 5rem 0 0 0; border-top: 4px solid var(--primary); }
  .footer-grid { display: grid; grid-template-columns: 2fr 1fr 1fr 1.5fr; gap: 3rem; padding-bottom: 4rem; }
  @media (max-width: 1024px) { .footer-grid { grid-template-columns: 1fr 1fr; gap: 2.5rem; } .brand-col { grid-column: span 2; } }
  @media (max-width: 576px) { .footer-grid { grid-template-columns: 1fr; } .brand-col { grid-column: span 1; } }
  .footer-logo { height: 60px; width: auto; margin-bottom: 1.5rem; filter: brightness(1.2); }
  .brand-desc { color: #94a3b8; font-size: 0.95rem; line-height: 1.8; max-width: 400px; }
  .col-title { color: var(--white); font-size: 1.1rem; font-weight: 700; margin-bottom: 1.25rem; position: relative; padding-bottom: 0.5rem; }
  .col-title::after { content: ''; position: absolute; bottom: 0; right: 0; width: 35px; height: 3px; background-color: var(--accent); border-radius: 2px; }
  .col-links { list-style: none; display: flex; flex-direction: column; gap: 0.6rem; }
  .col-links a, .col-links span { color: #94a3b8; font-weight: 500; transition: var(--transition-smooth); font-size: 0.9rem; }
  .col-links a:hover { color: var(--white); }
  .areas-list li span { font-size: 0.85rem; }
  .contact-item { display: flex; align-items: center; gap: 0.75rem; color: #94a3b8; font-size: 0.9rem; }
  .contact-item svg { color: var(--accent); flex-shrink: 0; }
  .contact-item a { color: #94a3b8; }
  .contact-item a:hover { color: var(--white); }
  .footer-socials { display: flex; gap: 0.75rem; margin-top: 1.25rem; }
  .social-icon { width: 38px; height: 38px; border-radius: 50%; display: flex; align-items: center; justify-content: center; background-color: #1e293b; color: var(--white); transition: var(--transition-smooth); }
  .social-icon:hover { transform: translateY(-3px); }
  .whatsapp-icon:hover { background-color: #25D366; }
  .twitter-icon:hover { background-color: #1DA1F2; }
  .instagram-icon:hover { background: linear-gradient(45deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888); }
  .snapchat-icon:hover { background-color: #FFFC00; color: #000; }
  .footer-bottom { background-color: #020617; padding: 1.5rem 0; border-top: 1px solid #1e293b; }
  .bottom-content { display: flex; justify-content: space-between; align-items: center; color: #64748b; font-size: 0.875rem; }
  @media (max-width: 768px) { .bottom-content { flex-direction: column; gap: 0.5rem; text-align: center; } }
  .developed-by { color: #64748b; }
</style>
