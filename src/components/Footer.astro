---
const today = new Date();
---

<footer class="footer-section">
	<div class="container footer-grid">
		<!-- Column 1: Brand Info -->
		<div class="footer-col brand-col">
			<img src="/logo.png" alt="التميز لنقل الأثاث بالرياض" class="footer-logo" />
			<p class="brand-desc">
				شركة التميز لنقل العفش بالرياض هي خيارك الأول لخدمات نقل الأثاث السكني والتجاري. نقدم خدمات فك وتغليف وتركيب متكاملة بأيدي فنيين محترفين ومع الضمان.
			</p>
		</div>

		<!-- Column 2: Quick Links -->
		<div class="footer-col">
			<h3 class="col-title">روابط سريعة</h3>
			<ul class="col-links">
				<li><a href="/#hero">الرئيسية</a></li>
				<li><a href="/services">خدماتنا</a></li>
				<li><a href="/#calculator">حاسبة الأسعار</a></li>
				<li><a href="/#why-us">لماذا نحن؟</a></li>
				<li><a href="/#faq">الأسئلة الشائعة</a></li>
				<li><a href="/blog">المدونة</a></li>
			</ul>
		</div>

		<!-- Column 3: Contact Info -->
		<div class="footer-col contact-col">
			<h3 class="col-title">معلومات الاتصال</h3>
			<ul class="col-links">
				<li class="contact-item">
					<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
					<span>الرياض، المملكة العربية السعودية</span>
				</li>
				<li class="contact-item">
					<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
					<a href="tel:+966500000000" dir="ltr">+966 50 000 0000</a>
				</li>
				<li class="contact-item">
					<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
					<a href="mailto:info@naqleafash-riyadh.com">info@naqleafash-riyadh.com</a>
				</li>
			</ul>
			<div class="footer-socials">
				<a href="https://wa.me/966500000000" target="_blank" class="social-icon whatsapp-icon" aria-label="تواصل معنا عبر واتساب">
					<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
				</a>
			</div>
		</div>
	</div>
	
	<div class="footer-bottom">
		<div class="container bottom-content">
			<p>&copy; {today.getFullYear()} التميز لنقل الأثاث بالرياض. جميع الحقوق محفوظة.</p>
			<p class="developed-by">صُمم بكل حب ❤️ لخدمة أهالي الرياض</p>
		</div>
	</div>
</footer>

<style>
	.footer-section {
		background-color: #0f172a; /* Slate 900 */
		color: #e2e8f0; /* Slate 200 */
		padding: 5rem 0 0 0;
		border-top: 4px solid var(--primary);
	}

	.footer-grid {
		display: grid;
		grid-template-columns: 2fr 1fr 1.5fr;
		gap: 4rem;
		padding-bottom: 4rem;
	}

	@media (max-width: 992px) {
		.footer-grid {
			grid-template-columns: 1fr 1fr;
			gap: 3rem;
		}
		
		.brand-col {
			grid-column: span 2;
		}
	}

	@media (max-width: 576px) {
		.footer-grid {
			grid-template-columns: 1fr;
			gap: 2rem;
		}
		
		.brand-col {
			grid-column: span 1;
		}
	}

	.footer-logo {
		height: 60px;
		width: auto;
		margin-bottom: 1.5rem;
		filter: drop-shadow(0 2px 4px rgba(255, 255, 255, 0.1)) brightness(1.2);
	}

	.brand-desc {
		color: #94a3b8; /* Slate 400 */
		font-size: 0.95rem;
		line-height: 1.8;
		max-width: 400px;
	}

	.col-title {
		color: var(--white);
		font-size: 1.25rem;
		font-weight: 700;
		margin-bottom: 1.5rem;
		position: relative;
		padding-bottom: 0.5rem;
	}

	.col-title::after {
		content: '';
		position: absolute;
		bottom: 0;
		right: 0;
		width: 40px;
		height: 3px;
		background-color: var(--accent);
		border-radius: 2px;
	}

	.col-links {
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.col-links a {
		color: #94a3b8;
		font-weight: 500;
		transition: var(--transition-smooth);
	}

	.col-links a:hover {
		color: var(--white);
		transform: translateX(-5px);
		display: inline-block;
	}

	.contact-item {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		color: #94a3b8;
	}

	.contact-item svg {
		color: var(--accent);
		flex-shrink: 0;
	}

	.contact-item a {
		color: #94a3b8;
	}

	.contact-item a:hover {
		color: var(--white);
	}

	.footer-socials {
		display: flex;
		gap: 1rem;
		margin-top: 1.5rem;
	}

	.social-icon {
		width: 40px;
		height: 40px;
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		background-color: #1e293b;
		color: var(--white);
		transition: var(--transition-smooth);
	}

	.social-icon:hover {
		transform: translateY(-3px);
	}

	.whatsapp-icon:hover {
		background-color: #25D366;
	}

	.footer-bottom {
		background-color: #020617; /* Slate 950 */
		padding: 1.5rem 0;
		border-top: 1px solid #1e293b;
	}

	.bottom-content {
		display: flex;
		justify-content: space-between;
		align-items: center;
		color: #64748b;
		font-size: 0.9rem;
	}

	@media (max-width: 768px) {
		.bottom-content {
			flex-direction: column;
			gap: 0.75rem;
			text-align: center;
		}
	}

	.developed-by {
		color: #64748b;
	}
</style>
